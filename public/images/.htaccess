# Permitir acceso público a las imágenes para que se muestren en los correos
# incluso si el sitio principal está protegido con contraseña (Basic Auth)

<IfModule mod_authz_core.c>
    Require all granted
</IfModule>

<IfModule !mod_authz_core.c>
    Order Allow,Deny
    Allow from all
    Satisfy Any
</IfModule>
